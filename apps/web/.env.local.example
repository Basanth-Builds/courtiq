# ============================================================
# Court IQ — Environment Variables
# Copy this to .env.local and fill in the values
# NEVER commit .env.local to git
# ============================================================

# ── Admin Authentication (REQUIRED) ────────────────────────
# Set a strong password for admin access. Use a random string generator.
# This protects the /admin dashboard where organizers update scores.
ADMIN_PASSWORD=

# ── NextAuth ────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# ── Firebase Client (public — safe in NEXT_PUBLIC_) ───────
# Optional: Only needed if Firebase auth is being used
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyD3XQoW5VPY2gL2i0pU0A1E9TzBm4aLnDQ
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=court-iq-152f7.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=court-iq-152f7
NEXT_PUBLIC_FIREBASE_APP_ID=1:1097094147815:web:ae0b7386b241f5473cfc42
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=1097094147815

# ── Firebase Admin (private — server only) ────────────
# Optional: Only needed if Firebase auth is being used
FIREBASE_PROJECT_ID=court-iq-152f7
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-fbsvc@court-iq-152f7.iam.gserviceaccount.com
# Paste the private key exactly as-is (with \n newlines) from the service account JSON
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# ── Database (optional in dev) ───────────────────────
# Optional: Only needed if connecting to PostgreSQL with Prisma
# DATABASE_URL=postgresql://...
