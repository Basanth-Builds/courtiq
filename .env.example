# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/courtiq"

# ─── Auth ────────────────────────────────────────────────────
# Required by NextAuth v5. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-real-random-secret"

# ─── App ─────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── SMS / OTP ───────────────────────────────────────────────
# Twilio credentials for phone OTP
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# ─── Cloudflare ──────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
