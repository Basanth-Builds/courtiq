# ─── Database ────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL="postgresql://postgres:password@localhost:5432/courtiq"

# ─── Auth ────────────────────────────────────────────────────
# Required by NextAuth v5. Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-a-real-random-secret"

# ─── App ─────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ─── Firebase (Phone Auth) ───────────────────────────────────
# Create a Firebase project and enable Phone Authentication
NEXT_PUBLIC_FIREBASE_API_KEY="your_firebase_api_key"
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="123456789012"
NEXT_PUBLIC_FIREBASE_APP_ID="1:123456789012:web:abcdef123456"

# ─── SMS / OTP (legacy fallback) ─────────────────────────────
# Twilio credentials for phone OTP
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your_auth_token"
TWILIO_PHONE_NUMBER="+1234567890"

# ─── Cloudflare ──────────────────────────────────────────────
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_API_TOKEN=""
